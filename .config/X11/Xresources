!colorscheme
#include </home/red/.config/colorschemes/nord>

*font: xft:Anonymice Nerd Font:size=18
*boldFont: xft:InconsolataLGC Nerd Font :bold:size=18
*italicFont: xft:InconsolataLGC Nerd Font:italic:size=18
*letterSpace:0
! General settings
*saveLines: 4000
*scrollBar: False
*scrollstyle: rxvt
